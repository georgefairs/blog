---
/**
 * Renders marimo "islands" — individual reactive notebook cells embedded inline.
 *
 * The body markup is generated by `notebooks/gen_islands.py` and imported raw, so
 * MDX never parses it (the island HTML contains `{` which MDX would treat as JSX).
 * The runtime <script> is emitted as a real `is:inline` tag — scripts injected via
 * `set:html` are NOT executed by the browser, so it must not go through set:html.
 *
 * Theming: marimo renders some widgets (e.g. the slider) into SHADOW DOM and ships
 * no colour override hooks, so external CSS can't reach them. We define our palette
 * as inheritable `--mz-*` custom properties (which DO pierce shadow boundaries) and
 * a script injects a stylesheet into each shadow root remapping marimo's own vars
 * (`--primary`, `--foreground`, …) onto ours. Light-DOM content is themed directly.
 */
import body from "@/assets/marimo/logistic.body.html?raw";

const ISLANDS_VERSION = "0.23.9";
const CDN = `https://cdn.jsdelivr.net/npm/@marimo-team/islands@${ISLANDS_VERSION}/dist`;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;500;700&family=Lora&family=PT+Sans:wght@400;700&display=swap"
  rel="stylesheet"
/>
<link
  rel="stylesheet"
  href={`${CDN}/style.css`}
  title="marimo-islands"
  crossorigin="anonymous"
/>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.css"
  crossorigin="anonymous"
/>

<div class="marimo-islands" set:html={body} />

<script type="module" is:inline src={`${CDN}/main.js`}></script>

<script is:inline>
  (function () {
    // 1. Mirror the blog's [data-theme] onto the `.dark` class marimo's Tailwind
    //    `dark:` utilities key off.
    function syncDark() {
      var dark = document.documentElement.getAttribute("data-theme") === "dark";
      document.querySelectorAll(".marimo-islands").forEach(function (el) {
        el.classList.toggle("dark", dark);
      });
    }
    syncDark();
    new MutationObserver(syncDark).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });

    // 2. Inject theme CSS into shadow roots (slider etc.). It references the
    //    inheritable --mz-* props, so a theme toggle updates it automatically.
    var SHADOW_CSS = [
      ":host, .marimo {",
      "  --primary: var(--mz-accent) !important;",
      "  --primary-foreground: var(--mz-accent-fg) !important;",
      "  --accent: var(--mz-accent) !important;",
      "  --accent-foreground: var(--mz-accent-fg) !important;",
      "  --foreground: var(--mz-fg) !important;",
      "  --background: var(--mz-bg) !important;",
      "  --border: var(--mz-border) !important;",
      "  --muted: var(--mz-muted) !important;",
      "  --muted-foreground: var(--mz-muted-fg) !important;",
      "  --marimo-text-font: var(--font-app);",
      "  --marimo-heading-font: var(--font-app);",
      "  --marimo-monospace-font: var(--font-app);",
      "}",
      ".bg-primary { background-color: var(--mz-accent) !important; }",
      ".text-primary { color: var(--mz-fg) !important; }",
      ".border-primary { border-color: var(--mz-accent) !important; }",
      ".marimo strong, .marimo b { color: var(--mz-fg) !important; }",
      // The slider hardcodes Tailwind blue in light mode (range fill + thumb).
      ".bg-blue-500 { background-color: var(--mz-accent) !important; }",
      ".border-blue-500 { border-color: var(--mz-accent) !important; }",
      '[role="slider"] { border-color: var(--mz-accent) !important; }',
      ".hover\\:bg-blue-300:hover, .focus\\:bg-blue-300:focus { background-color: var(--mz-accent) !important; }",
      // Darken the (single, baked) plot image in light mode; see --mz-plot-filter.
      ".marimo img { filter: var(--mz-plot-filter); }",
    ].join("\n");

    function inject(root) {
      if (!root || root.__mzThemed) return;
      var s = document.createElement("style");
      s.textContent = SHADOW_CSS;
      root.appendChild(s);
      root.__mzThemed = true;
    }
    function walk(node) {
      if (!node) return;
      if (node.shadowRoot) {
        inject(node.shadowRoot);
        walk(node.shadowRoot);
      }
      var kids = node.children;
      if (kids) for (var i = 0; i < kids.length; i++) walk(kids[i]);
    }
    function scan() {
      document.querySelectorAll(".marimo-islands").forEach(walk);
    }
    // Hydration is async (Pyodide), so shadow roots appear over several seconds.
    scan();
    var n = 0;
    var t = setInterval(function () {
      scan();
      if (++n > 40) clearInterval(t);
    }, 300);
  })();
</script>

<style is:global>
  /* Minimal Mono palette as inheritable props (pierce shadow DOM). */
  .marimo-islands {
    --mz-bg: #ffffff;
    --mz-fg: #1a1a1a;
    --mz-border: #e5e7eb;
    --mz-muted: #f3f4f6;
    --mz-muted-fg: #6b7280;
    --mz-accent: #111827;
    --mz-accent-fg: #ffffff;
    /* Plot is one baked grayscale image; darken its ink for light backgrounds. */
    --mz-plot-filter: brightness(0.5);
  }
  :root[data-theme="dark"] .marimo-islands {
    --mz-bg: #111111;
    --mz-fg: #e5e5e5;
    --mz-border: #2a2a2a;
    --mz-muted: #1f1f1f;
    --mz-muted-fg: #a1a1aa;
    --mz-accent: #fafafa;
    --mz-accent-fg: #111111;
    --mz-plot-filter: none;
  }

  /* Light-DOM content (markdown, plot, code) — map marimo vars to ours. */
  .marimo-islands .marimo {
    --marimo-text-font: var(--font-app);
    --marimo-heading-font: var(--font-app);
    --marimo-monospace-font: var(--font-app);
    --background: var(--mz-bg);
    --foreground: var(--mz-fg);
    --border: var(--mz-border);
    --muted: var(--mz-muted);
    --muted-foreground: var(--mz-muted-fg);
    --accent: var(--mz-accent);
    --accent-foreground: var(--mz-accent-fg);
    --primary: var(--mz-accent);
    --primary-foreground: var(--mz-accent-fg);
    color-scheme: light;
    background: transparent;
  }
  :root[data-theme="dark"] .marimo-islands .marimo {
    color-scheme: dark;
  }

  .marimo-islands marimo-island,
  .marimo-islands marimo-cell-output,
  .marimo-islands .marimo-cell {
    background: transparent !important;
  }
  .marimo-islands .bg-primary {
    background-color: var(--mz-accent) !important;
  }
  .marimo-islands .text-primary {
    color: var(--mz-fg) !important;
  }
  .marimo-islands .border-primary {
    border-color: var(--mz-accent) !important;
  }
  .marimo-islands .marimo strong,
  .marimo-islands .marimo b {
    color: var(--mz-fg) !important;
  }
  .marimo-islands .marimo img {
    filter: var(--mz-plot-filter);
  }

  /* Breathing room between cells. */
  .marimo-islands marimo-island {
    display: block;
  }
  .marimo-islands marimo-island + marimo-island {
    margin-top: 1.5rem;
  }
</style>
